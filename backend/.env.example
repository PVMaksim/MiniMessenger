# ─── Скопируй этот файл в .env и заполни своими значениями ───────────────────
# cp .env.example .env

# Окружение: development | production
NODE_ENV=development

# Порт сервера
PORT=4000

# ─── База данных (PostgreSQL) ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=minimessenger
DB_USER=mmuser
DB_PASSWORD=mmpassword

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО замени на свой длинный случайный секрет!
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── Файлы ────────────────────────────────────────────────────────────────────
# Максимальный размер загружаемого файла в байтах (20 МБ = 20971520)
MAX_FILE_SIZE=20971520

# ─── CORS ─────────────────────────────────────────────────────────────────────
# В продакшене укажи URL фронтенда (без слэша на конце)
# Например: https://mymessenger.com
CLIENT_URL=http://localhost:5173

# ─── Уведомления об ошибках (Telegram) ─────────────────────────────────────────
# Опционально: для получения уведоманий о критических ошибках в production
# 1. Создай бота через @BotFather, получи токен
# 2. Узнай свой Telegram ID через @userinfobot
# 3. Напиши боту первым сообщением
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=
