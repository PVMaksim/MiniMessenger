# backend/.env
# ⚠️  НЕ КОММИТИТЬ В GIT — этот файл в .gitignore
# Для продакшена замени все значения на настоящие.

NODE_ENV=development
PORT=4000

# ── База данных ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=minimessenger
DB_USER=mmuser
DB_PASSWORD=mmpassword

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Оставь пустым для dev (Redis без пароля локально)
# В продакшене: REDIS_PASSWORD=придумай_сложный_пароль
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# FIX: заменён placeholder на валидный dev-секрет (64 hex-символа)
# В продакшене сгенерируй свой:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=4a7d1ed414474e4033ac29ccb8653d9b3f3ffd8f4e3d9e8c1a2b0f6e5d4c3b2a
JWT_EXPIRES_IN=7d

# ── Файлы ─────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=20971520

# ── CORS ──────────────────────────────────────────────────────────────────────
# В продакшене: https://yourdomain.com
CLIENT_URL=http://localhost:5173
